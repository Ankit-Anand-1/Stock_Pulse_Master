{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "fcmToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Holding": {
      "title": "Holding",
      "description": "A stock holding in a user's portfolio",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "quantity": { "type": "number" },
        "averagePrice": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "symbol", "quantity", "averagePrice", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A buy or sell transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "symbol", "type", "quantity", "price", "timestamp"]
    },
    "Alert": {
      "title": "Alert",
      "description": "A price alert for a stock",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "targetPrice": { "type": "number" },
        "condition": { "type": "string", "enum": ["above", "below"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "symbol", "targetPrice", "condition", "active", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An in-app notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "body", "read", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/portfolios/{portfolioId}": {
      "schema": "Holding",
      "description": "Stock holdings indexed by a combined userId_symbol key or similar"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Log of all trades"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Price alerts for users"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
